PORT=3000

# Frontend base URL for plant QR deep links
QR_BASE_URL=http://localhost:3000

# Spaces
MAX_SPACES_PER_USER=5
SPACE_INVITATION_DEFAULT_EXPIRY_HOURS=24
SPACE_INVITATION_CODE_COLLISION_MAX_RETRIES=5

# PostgreSQL — individual connection vars (DATABASE_URL is NOT supported)
DATABASE_DRIVER=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=gardenia
DATABASE_PASSWORD=secret
DATABASE_DATABASE=gardenia_db

# MongoDB
MONGO_URI=mongodb://localhost:27017/gardenia

# Auth
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_TTL_DAYS=30
REFRESH_COOKIE_NAME=refresh_token

# OAuth — general
# 32-byte key for AES-256-GCM encryption of provider tokens (openssl rand -base64 32)
OAUTH_TOKEN_ENC_KEY=a2tra2tra2tra2tra2tra2tra2tra2tra2tra2tra2s=
# Secret used to sign the OAuth state JWT (CSRF protection)
OAUTH_STATE_SECRET=change_me_in_production

# OAuth — Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/oauth/google/callback

# OAuth — GitHub
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3000/auth/oauth/github/callback

# OAuth — Apple (Sign in with Apple)
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
# PEM private key as single-line string with literal \n sequences
APPLE_PRIVATE_KEY=
APPLE_CALLBACK_URL=http://localhost:3000/auth/oauth/apple/callback

# Frontend base URL (used for OAuth post-login redirects)
FRONTEND_URL=http://localhost:3001

# Allowed browser origins for credentialed CORS (comma-separated).
# Falls back to FRONTEND_URL when unset. Required in production.
# CORS_ORIGINS=http://localhost:3001,https://app.example.com

# Sentry (optional — SDK disabled when SENTRY_DSN is unset)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=1.0
SENTRY_PROFILE_SESSION_SAMPLE_RATE=1.0
# Kafka — domain event forwarding (opt-in; app boots without a broker when disabled)
KAFKA_ENABLED=false
# Comma-separated broker list — required when KAFKA_ENABLED=true
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=gardenia-api
# Topics are ${KAFKA_TOPIC_PREFIX}.${module}, e.g. gardenia-api.plants
KAFKA_TOPIC_PREFIX=gardenia-api
KAFKA_SSL=false
# SASL is optional — set username + password to enable
KAFKA_SASL_MECHANISM=plain
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=

# Files — uploads and storage (all optional; defaults work out of the box)
# Max accepted upload size in bytes (default 10 MB)
FILES_MAX_SIZE_BYTES=10485760
# Comma-separated MIME allowlist (default: image/jpeg,image/png,image/webp)
FILES_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp
# Optional absolute base prepended to resolved file URLs (e.g. https://api.example.com)
FILES_PUBLIC_BASE_URL=
# Storage backend: database (default) or s3
FILES_STORAGE_DRIVER=database
# S3 settings — only required when FILES_STORAGE_DRIVER=s3
FILES_S3_BUCKET=
FILES_S3_REGION=us-east-1
# Custom endpoint for S3-compatible stores (MinIO, LocalStack, etc.)
FILES_S3_ENDPOINT=
# Set to true for path-style URLs (common with local S3-compatible endpoints)
FILES_S3_FORCE_PATH_STYLE=false
FILES_S3_ACCESS_KEY_ID=
FILES_S3_SECRET_ACCESS_KEY=
# Optional key prefix inside the bucket (no leading/trailing slashes)
FILES_S3_KEY_PREFIX=

# PlantNet — photo-based plant identification (plant-identification context)
# Required. Obtain from my.plantnet.org. NEVER commit the real key.
PLANTNET_API_KEY=
# Dataset/project slug, defaults to "all" (PlantNet's world flora dataset)
PLANTNET_PROJECT=all
# Score threshold (0-1) above which the top candidate auto-resolves against GBIF
PLANTNET_MIN_CONFIDENCE=0.2
