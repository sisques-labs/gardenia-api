PORT=3000

# Frontend base URL for plant QR deep links
QR_BASE_URL=http://localhost:3000

# Spaces
MAX_SPACES_PER_USER=5
SPACE_INVITATION_DEFAULT_EXPIRY_HOURS=24
SPACE_INVITATION_CODE_COLLISION_MAX_RETRIES=5

# PostgreSQL — individual connection vars (DATABASE_URL is NOT supported)
DATABASE_DRIVER=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=gardenia
DATABASE_PASSWORD=secret
DATABASE_DATABASE=gardenia_db

# MongoDB
MONGO_URI=mongodb://localhost:27017/gardenia

# Auth
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_TTL_DAYS=30
REFRESH_COOKIE_NAME=refresh_token

# OAuth — general
# 32-byte hex key for AES-256-GCM encryption of provider tokens (openssl rand-hex 32)
OAUTH_TOKEN_ENC_KEY=change_me_32_bytes_hex_in_production
# Secret used to sign the OAuth state JWT (CSRF protection)
OAUTH_STATE_SECRET=change_me_in_production

# OAuth — Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/oauth/google/callback

# OAuth — GitHub
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3000/auth/oauth/github/callback

# OAuth — Apple (Sign in with Apple)
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
# PEM private key as single-line string with literal \n sequences
APPLE_PRIVATE_KEY=
APPLE_CALLBACK_URL=http://localhost:3000/auth/oauth/apple/callback

# Frontend base URL (used for OAuth post-login redirects)
FRONTEND_URL=http://localhost:3001

# Task Queue
TASK_PROVIDER=redis
TASK_IDEMPOTENCY_TTL_SECONDS=3600

# Redis (TASK_PROVIDER=redis)
TASK_REDIS_URL=redis://localhost:6379

# SQS (TASK_PROVIDER=sqs)
# Leave TASK_SQS_ACCESS_KEY_ID / SECRET empty to use IAM role (recommended in AWS)
TASK_SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789/gardenia-tasks.fifo
TASK_SQS_REGION=us-east-1
TASK_SQS_ACCESS_KEY_ID=
TASK_SQS_SECRET_ACCESS_KEY=
