{
  "extends": "./tsconfig.json",
  "exclude": ["node_modules", "test", "dist", "scripts", "**/*spec.ts"],
  "compilerOptions": {
    "rootDir": "./src",
    "tsBuildInfoFile": "./dist/.tsbuildinfo",
    "paths": {
      "@core/*": ["src/core/*"],
      "@contexts/*": ["src/contexts/*"],
      "@shared/*": ["src/shared/*"]
    }
  }
}
